        <activity android:name=".activitys_javaclass.ProfileActivity"/>
        <activity android:name=".activitys_javaclass.MessageActivity"/>
        <activity android:name=".activitys_javaclass.HistoryActivity"/>
        <activity android:name=".activitys_javaclass.LgpdProfileActivity"/>
    </application>

    <uses-permission android:name="android.permission.INTERNET"></uses-permission>

</manifest>