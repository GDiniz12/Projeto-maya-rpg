<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lightgrey"
    tools:context=".ForgotPasswordActivity">

    <LinearLayout
        android:id="@+id/cardForgetPassword"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_centerHorizontal="true"
        android:layout_centerInParent="true"
        android:elevation="6dp"
        android:background="@drawable/rounded">

        <com.google.android.material.button.MaterialButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voltar para o login"
            android:textColor="@color/lightblue"
            app:icon="@drawable/ic_arrow_back"
            app:iconTint="@color/lightblue"
            app:iconSize="25dp"
            android:backgroundTint="@color/white"
            android:layout_marginLeft="-25dp"
            android:fontFamily="@font/roboto_medium"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recuperar senha"
            android:textColor="@color/black"
            android:fontFamily="@font/roboto_medium"/>

        <TextView
            android:layout_marginTop="5dp"
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Informe seu e-mail cadastrado e enviaremos um código para redefinir sua senha"
            android:textColor="@color/grey"
            android:fontFamily="@font/roboto_medium"/>

        <TextView
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E-mail"
            android:textColor="@color/black"
            android:fontFamily="@font/roboto_medium" />

        <EditText
            android:id="@+id/editEmail"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:hint="seu@email.com"
            android:textSize="15dp"
            android:fontFamily="@font/roboto_medium"
            android:background="@drawable/rounded"
            android:backgroundTint="@color/lightgrey"
            android:padding="10dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enviar código"
            android:textColor="@color/white"
            android:fontFamily="@font/roboto_medium"
            android:background="@drawable/rounded_button"
            app:backgroundTint="@null"/>
    </LinearLayout>

</RelativeLayout>